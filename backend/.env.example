# ─── Optional Node/Mongo Backend ──────────────────────────────
# This file is only for the separate backend/ app.
# It is NOT used by the Java + MySQL application in java-app/.
# Copy this file to .env and fill in your own local values.
# Never commit real secrets here.

MONGODB_URI=<your_mongodb_connection_uri>
JWT_SECRET=<your_random_jwt_secret>
PORT=5001
CORS_ORIGIN=http://localhost:3000
